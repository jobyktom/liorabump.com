NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=google-search-console-meta-token

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Hostinger MySQL migration target.
# These are used by `npm run migrate:supabase-to-mysql`.
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=u123456789_liorabump
MYSQL_USER=u123456789_liorabump
MYSQL_PASSWORD=your-mysql-password
MIGRATION_SECRET=generate-a-long-random-one-time-secret
DATABASE_URL=mysql://user:password@127.0.0.1:3306/database

# Custom app authentication
NEXTAUTH_URL=http://127.0.0.1:3000
NEXTAUTH_SECRET=generate-a-long-random-secret
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# Stripe test mode values
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PREMIUM_PRICE_ID=price_replace_me
STRIPE_FAMILY_PRICE_ID=price_replace_me

# Error monitoring (Sentry)
NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
# Optional: enables readable production stack traces in Sentry during Hostinger builds.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
